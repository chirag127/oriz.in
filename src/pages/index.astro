---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.jsx";
import Footer from "../components/Footer.jsx";
import Card from "../components/Card.jsx";
import orbit from "../assets/hero-orbit.svg";

const posts = Object.values(import.meta.glob("./blog/*.md", { eager: true }))
  .sort((a, b) => new Date(b.frontmatter.publishDate).valueOf() - new Date(a.frontmatter.publishDate).valueOf())
  .slice(0, 3);

const productCards = [
  {
    eyebrow: "Finance",
    title: "Finance Tools",
    description:
      "Credit card discovery, calculators, and personal finance utilities designed for Indian consumers and modern fintech workflows.",
    href: "https://finance.oriz.in",
    cta: "Visit finance.oriz.in",
    accent: "brand"
  },
  {
    eyebrow: "Developer",
    title: "Developer Tools",
    description:
      "High-speed utilities for API testing, debugging, and building internal workflows without unnecessary friction.",
    href: "/about",
    cta: "See what Oriz is building",
    accent: "ink"
  },
  {
    eyebrow: "Identity",
    title: "Identity Tools",
    description:
      "Trust and verification products that simplify onboarding, identity checks, and secure user access at scale.",
    href: "/contact",
    cta: "Talk to the team",
    accent: "mint"
  }
];

const features = [
  {
    title: "Fast & Reliable",
    description: "Astro-first architecture keeps pages static, lightweight, and extremely fast to load."
  },
  {
    title: "Privacy Focused",
    description: "Products are designed with practical data minimization, transparent policies, and secure defaults."
  },
  {
    title: "Free & Accessible",
    description: "Oriz tools are built to be useful from day one, with simple interfaces and wide device compatibility."
  }
];
---

<BaseLayout
  title="Building Powerful Tools for the Internet"
  description="Oriz is a technology company building finance, developer, and identity tools designed for speed, simplicity, and scale."
  path="/"
>
  <Navbar client:load />
  <main class="pb-24">
    <section class="shell grid gap-14 pb-18 pt-12 lg:grid-cols-[1.08fr_0.92fr] lg:items-center lg:pt-16">
      <div class="space-y-8">
        <span class="eyebrow">Technology Holding Company</span>
        <div class="space-y-5">
          <h1 class="max-w-3xl text-5xl font-semibold tracking-[-0.04em] text-ink sm:text-6xl lg:text-7xl">
            Building Powerful Tools for the Internet
          </h1>
          <p class="max-w-2xl text-lg leading-8 text-slate sm:text-xl">
            Finance, Developer, and Identity tools designed for speed, simplicity, and
            scale.
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
          <a
            href="https://finance.oriz.in"
            class="inline-flex items-center justify-center rounded-full bg-ink px-6 py-3 text-sm font-semibold text-white hover:bg-brand"
          >
            Explore Finance Tools
          </a>
          <a
            href="#products"
            class="inline-flex items-center justify-center rounded-full border border-line bg-white px-6 py-3 text-sm font-semibold text-ink hover:border-brand hover:text-brand"
          >
            View Products
          </a>
        </div>
        <dl class="grid gap-4 sm:grid-cols-3">
          <div class="surface p-5">
            <dt class="text-sm font-medium text-slate">Products</dt>
            <dd class="mt-2 text-3xl font-semibold tracking-tight text-ink">3+</dd>
          </div>
          <div class="surface p-5">
            <dt class="text-sm font-medium text-slate">Approach</dt>
            <dd class="mt-2 text-3xl font-semibold tracking-tight text-ink">Fast</dd>
          </div>
          <div class="surface p-5">
            <dt class="text-sm font-medium text-slate">Availability</dt>
            <dd class="mt-2 text-3xl font-semibold tracking-tight text-ink">24/7</dd>
          </div>
        </dl>
      </div>
      <div class="surface relative overflow-hidden p-4 sm:p-6">
        <div class="absolute inset-0 bg-gradient-to-br from-brand/10 via-transparent to-aqua/10" />
        <Image
          src={orbit}
          alt="Oriz product ecosystem illustration"
          widths={[640, 960]}
          sizes="(max-width: 1024px) 100vw, 42rem"
          class="relative z-10 w-full animate-float"
        />
      </div>
    </section>

    <section id="products" class="shell py-14">
      <div class="mb-10 space-y-4">
        <span class="eyebrow">Products</span>
        <h2 class="section-title">A focused platform for useful internet products</h2>
        <p class="section-copy">
          Oriz operates as a parent company, building and supporting category-specific tools
          that are practical, trustworthy, and built to scale.
        </p>
      </div>
      <div class="grid-fade grid gap-6 lg:grid-cols-3">
        {productCards.map((card) => <Card {...card} />)}
      </div>
    </section>

    <section class="shell py-14">
      <div class="surface p-8 sm:p-10">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <div class="space-y-4">
            <span class="eyebrow">Why Oriz</span>
            <h2 class="section-title">Built for clarity, trust, and steady execution</h2>
            <p class="section-copy max-w-xl">
              The company site is intentionally clean and direct. It establishes trust,
              explains the product direction, and gives partners, users, and search engines
              a clear understanding of what Oriz does.
            </p>
          </div>
          <div class="grid gap-5 sm:grid-cols-3">
            {features.map((feature) => (
              <div class="rounded-[28px] border border-line bg-mist p-6">
                <h3 class="text-lg font-semibold tracking-tight text-ink">{feature.title}</h3>
                <p class="mt-3 text-sm leading-7 text-slate">{feature.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="shell py-14">
      <div class="mb-10 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="space-y-4">
          <span class="eyebrow">Latest Writing</span>
          <h2 class="section-title">Search-friendly guides from the Oriz team</h2>
        </div>
        <a href="/blog" class="text-sm font-semibold text-brand hover:text-brand-dark">
          View all articles
        </a>
      </div>
      <div class="grid gap-6 lg:grid-cols-3">
        {posts.map((post) => (
          <Card
            eyebrow={post.frontmatter.category}
            title={post.frontmatter.title}
            description={post.frontmatter.description}
            href={post.url}
            cta="Read article"
            accent="brand"
          />
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
